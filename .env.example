# ============================================
# MG Prospect AI — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# No Coolify, configure essas variáveis na aba "Environment Variables".

# ---------- Banco de Dados ----------
POSTGRES_USER=mg_user
POSTGRES_PASSWORD=TROCAR_SENHA_SEGURA
POSTGRES_DB=mg_prospect

# ---------- Backend (FastAPI) ----------
SECRET_KEY=GERAR_CHAVE_SEGURA_COM_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- Google Places API ----------
GOOGLE_PLACES_API_KEY=

# ---------- Brevo (E-mail) ----------
BREVO_API_KEY=
BREVO_FROM_EMAIL=contato@mendoncagalvao.com.br

# ---------- Frontend URL (para CORS e links de e-mail) ----------
# Em produção, colocar o domínio real (ex: https://mgprospect.seudominio.com)
FRONTEND_URL=http://localhost

# ---------- n8n Webhook ----------
N8N_WEBHOOK_LEAD_INTEREST_URL=

# ---------- Porta do Frontend ----------
# Coolify gerencia a porta automaticamente, mas pode customizar aqui
FRONTEND_PORT=80
